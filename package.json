{
  "name": "blackjack-pro-phaser",
  "version": "1.1.0",
  "private": true,
  "type": "module",
  "description": "Modern responsive browser-only Blackjack simulation built with TypeScript, Vite, and Phaser. Catalina-compatible dependency pins.",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview --host 0.0.0.0",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "phaser": "3.80.1"
  },
  "devDependencies": {
    "@types/node": "18.19.39",
    "typescript": "5.4.5",
    "vite": "4.5.14",
    "vitest": "0.34.6"
  },
  "engines": {
    "node": ">=16.14 <21",
    "npm": ">=8"
  }
}
